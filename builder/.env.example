# Required
ANTHROPIC_API_KEY=sk-ant-...

# Where the mapping doc (masked->real) is written — never in the project dir
# Mac/Linux: ~/.bi-cohost/secure
# Windows:   C:\Users\YourName\.bi-cohost\secure
SECURE_DIR=~/.bi-cohost/secure

# Optional tuning
ADVISOR_MAX_TOKENS=2048
CONTRACT_MAX_ITERATIONS=5
