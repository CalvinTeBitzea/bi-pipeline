{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.9.0/schema.json",
  "name": "<VISUAL_NAME>",
  "position": {
    "x": <CHART_X>,
    "y": <CHART_Y>,
    "z": <CHART_Z>,
    "height": <CHART_HEIGHT>,
    "width": <CHART_WIDTH>,
    "tabOrder": <CHART_TAB_ORDER>
  },
  "visual": {
    "visualType": "lineStackedColumnComboChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "<DATE_TABLE>"
                    }
                  },
                  "Property": "<DATE_AXIS_COLUMN>"
                }
              },
              "queryRef": "<DATE_TABLE>.<DATE_AXIS_COLUMN>",
              "nativeQueryRef": "<DATE_AXIS_COLUMN>",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "<MEASURE_TABLE>"
                    }
                  },
                  "Property": "<VOLUME_MEASURE_NAME>"
                }
              },
              "queryRef": "<MEASURE_TABLE>.<VOLUME_MEASURE_NAME>",
              "nativeQueryRef": "<VOLUME_MEASURE_NATIVE_REF>"
            }
          ]
        },
        "Y2": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "<MEASURE_TABLE>"
                    }
                  },
                  "Property": "<GROWTH_MEASURE_NAME>"
                }
              },
              "queryRef": "<MEASURE_TABLE>.<GROWTH_MEASURE_NAME>",
              "nativeQueryRef": "<GROWTH_MEASURE_NATIVE_REF>"
            }
          ]
        }
      }
    },
    "objects": {
      "legend": [
        {
          "properties": {
            "show": {
              "expr": { "Literal": { "Value": "true" } }
            },
            "showTitle": {
              "expr": { "Literal": { "Value": "false" } }
            },
            "fontSize": {
              "expr": { "Literal": { "Value": "9D" } }
            },
            "italic": {
              "expr": { "Literal": { "Value": "true" } }
            }
          }
        }
      ],
      "categoryAxis": [
        {
          "properties": {
            "show": {
              "expr": { "Literal": { "Value": "true" } }
            },
            "maxMarginFactor": {
              "expr": { "Literal": { "Value": "<CATEGORY_MAX_MARGIN>" } }
            },
            "showAxisTitle": {
              "expr": { "Literal": { "Value": "false" } }
            },
            "labelColor": {
              "solid": {
                "color": {
                  "expr": { "ThemeDataColor": { "ColorId": 1, "Percent": 0.4 } }
                }
              }
            },
            "fontSize": {
              "expr": { "Literal": { "Value": "10D" } }
            }
          }
        }
      ],
      "valueAxis": [
        {
          "properties": {
            "show": {
              "expr": { "Literal": { "Value": "true" } }
            },
            "showAxisTitle": {
              "expr": { "Literal": { "Value": "false" } }
            },
            "labelColor": {
              "solid": {
                "color": {
                  "expr": { "ThemeDataColor": { "ColorId": 0, "Percent": 0 } }
                }
              }
            },
            "secShow": {
              "expr": { "Literal": { "Value": "false" } }
            },
            "secLabelColor": {
              "solid": {
                "color": {
                  "expr": { "ThemeDataColor": { "ColorId": 0, "Percent": 0 } }
                }
              }
            },
            "secStart": {
              "expr": { "Literal": { "Value": "<SECONDARY_Y_AXIS_START>" } }
            },
            "end": {
              "expr": { "Literal": { "Value": "<PRIMARY_Y_AXIS_END>" } }
            },
            "secEnd": {
              "expr": { "Literal": { "Value": "<SECONDARY_Y_AXIS_END>" } }
            }
          }
        }
      ],
      "dataPoint": [
        {
          "properties": {
            "fill": {
              "solid": {
                "color": {
                  "expr": { "ThemeDataColor": { "ColorId": <DATA_POINT_COLOR_ID>, "Percent": 0 } }
                }
              }
            }
          },
          "selector": {
            "data": [
              {
                "scopeId": {
                  "Comparison": {
                    "ComparisonKind": 0,
                    "Left": {
                      "Column": {
                        "Expression": {
                          "SourceRef": {
                            "Entity": "<DATA_POINT_ENTITY>"
                          }
                        },
                        "Property": "<DATA_POINT_CATEGORY_COLUMN>"
                      }
                    },
                    "Right": {
                      "Literal": {
                        "Value": "'<DATA_POINT_CATEGORY_VALUE>'"
                      }
                    }
                  }
                }
              }
            ]
          }
        }
      ],
      "labels": [
        {
          "properties": {
            "show": {
              "expr": { "Literal": { "Value": "true" } }
            },
            "detailFontSize": {
              "expr": { "Literal": { "Value": "10D" } }
            },
            "detailLabelPrecision": {
              "expr": { "Literal": { "Value": "1L" } }
            },
            "enableBackground": {
              "expr": { "Literal": { "Value": "false" } }
            }
          }
        },
        {
          "properties": {
            "labelPosition": {
              "expr": { "Literal": { "Value": "'Above'" } }
            }
          },
          "selector": {
            "metadata": "<MEASURE_TABLE>.<GROWTH_MEASURE_NAME>"
          }
        }
      ],
      "lineStyles": [
        {
          "properties": {
            "showMarker": {
              "expr": { "Literal": { "Value": "true" } }
            }
          }
        }
      ]
    },
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "show": {
              "expr": { "Literal": { "Value": "true" } }
            },
            "titleWrap": {
              "expr": { "Literal": { "Value": "true" } }
            },
            "fontColor": {
              "solid": {
                "color": {
                  "expr": { "ThemeDataColor": { "ColorId": 1, "Percent": 0.4 } }
                }
              }
            },
            "background": {
              "solid": {
                "color": {
                  "expr": { "Literal": { "Value": "null" } }
                }
              }
            },
            "fontSize": {
              "expr": { "Literal": { "Value": "12D" } }
            },
            "fontFamily": {
              "expr": { "Literal": { "Value": "'Arial'" } }
            },
            "text": {
              "expr": { "Literal": { "Value": "'<CHART_TITLE>'" } }
            }
          }
        }
      ],
      "background": [
        {
          "properties": {
            "show": {
              "expr": { "Literal": { "Value": "true" } }
            },
            "color": {
              "solid": {
                "color": {
                  "expr": { "Literal": { "Value": "'#FFFFFF'" } }
                }
              }
            },
            "transparency": {
              "expr": { "Literal": { "Value": "100D" } }
            }
          }
        }
      ],
      "padding": [
        {
          "properties": {
            "top": {
              "expr": { "Literal": { "Value": "5D" } }
            },
            "bottom": {
              "expr": { "Literal": { "Value": "0D" } }
            }
          }
        }
      ],
      "border": [
        {
          "properties": {
            "show": {
              "expr": { "Literal": { "Value": "true" } }
            },
            "color": {
              "solid": {
                "color": {
                  "expr": { "Literal": { "Value": "'#E6E6E6'" } }
                }
              }
            },
            "radius": {
              "expr": { "Literal": { "Value": "10D" } }
            },
            "width": {
              "expr": { "Literal": { "Value": "1D" } }
            }
          }
        }
      ]
    },
    "drillFilterOtherVisuals": true
  }
}
