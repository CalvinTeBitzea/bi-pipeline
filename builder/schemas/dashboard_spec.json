{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["spec_id", "created_at", "requirements_spec_id", "model_id", "pages"],
  "additionalProperties": false,
  "properties": {
    "spec_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "requirements_spec_id": { "type": "string" },
    "model_id": { "type": "string" },
    "template": { "type": "string" },
    "missing": { "type": "array", "items": { "type": "string" } },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["page_id", "name", "type", "visuals"],
        "additionalProperties": false,
        "properties": {
          "page_id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["overview", "detail", "drillthrough", "tooltip"] },
          "visuals": {
            "type": "array",
            "maxItems": 20,
            "items": {
              "type": "object",
              "required": ["visual_id", "type", "title", "measures", "dimensions", "accessibility_label"],
              "additionalProperties": false,
              "properties": {
                "visual_id": { "type": "string" },
                "type": {
                  "type": "string",
                  "enum": ["card", "bar", "line", "column", "pie", "donut", "table", "matrix", "slicer", "map", "scatter", "waterfall", "funnel", "gauge"]
                },
                "title": { "type": "string" },
                "measures": { "type": "array", "items": { "type": "string" } },
                "dimensions": { "type": "array", "items": { "type": "string" } },
                "accessibility_label": { "type": "string", "minLength": 1 },
                "filters": { "type": "array", "items": { "type": "string" } },
                "sort_by": { "type": "string" },
                "sort_direction": { "type": "string", "enum": ["asc", "desc"] },
                "skill": { "type": ["string", "null"] },
                "skill_params": { "type": "object", "additionalProperties": true },
                "grid": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "col": { "type": "integer" },
                    "row": { "type": "integer" },
                    "colSpan": { "type": "integer" },
                    "rowSpan": { "type": "integer" }
                  }
                },
                "layout": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "x": { "type": "number" },
                    "y": { "type": "number" },
                    "w": { "type": "number" },
                    "h": { "type": "number" },
                    "z": { "type": "number" },
                    "tabOrder": { "type": "number" }
                  }
                }
              }
            }
          },
          "global_filters": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
