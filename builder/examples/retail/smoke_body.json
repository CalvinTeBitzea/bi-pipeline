  "semantic_model": {
    "model_id": "retail_sales_v1",
    "created_at": "2026-06-15T00:00:00+00:00",
    "spec_id": "retail_req_v1",
    "measures": [
      {
        "name": "Net Revenue",
        "home_table": "Fact_Sales",
        "format_string": "\\$#,0",
        "description": "SUM(TotalAmount) - SUM(Discount)",
        "dax": "SUM('Fact_Sales'[TotalAmount]) - SUM('Fact_Sales'[Discount])"
      },
      {
        "name": "Gross Profit",
        "home_table": "Fact_Sales",
        "format_string": "\\$#,0",
        "description": "SUM(Profit)",
        "dax": "SUM('Fact_Sales'[Profit])"
      },
      {
        "name": "Profit Margin %",
        "home_table": "Fact_Sales",
        "format_string": "0.0%",
        "description": "Gross Profit / Net Revenue",
        "dax": "DIVIDE([Gross Profit], [Net Revenue])"
      },
      {
        "name": "Quantity Sold",
        "home_table": "Fact_Sales",
        "format_string": "#,0",
        "description": "SUM(Quantity)",
        "dax": "SUM('Fact_Sales'[Quantity])"
      },
      {
        "name": "Discount Rate %",
        "home_table": "Fact_Sales",
        "format_string": "0.0%",
        "description": "SUM(Discount) / SUM(TotalAmount)",
        "dax": "DIVIDE(SUM('Fact_Sales'[Discount]), SUM('Fact_Sales'[TotalAmount]))"
      },
      {
        "name": "Top Category Revenue",
        "home_table": "Fact_Sales",
        "format_string": "\\$#,0",
        "description": "Net Revenue of the top category",
        "dax": "MAXX(VALUES('Dim_Product'[Category]), [Net Revenue])"
      },
      {
        "name": "Active SKUs",
        "home_table": "Dim_Product",
        "format_string": "#,0",
        "description": "DISTINCTCOUNT ProductKey where IsActive",
        "dax": "CALCULATE(DISTINCTCOUNT('Dim_Product'[ProductKey]), 'Dim_Product'[IsActive] = TRUE())"
      },
      {
        "name": "Pct Rev Top10 SKUs",
        "home_table": "Fact_Sales",
        "format_string": "0.0%",
        "description": "Top-10 SKU share of Net Revenue (Pareto)",
        "dax": "DIVIDE([Net Revenue (Top 10 SKU)], [Net Revenue])"
      },
      {
        "name": "Avg Category Margin %",
        "home_table": "Fact_Sales",
        "format_string": "0.0%",
        "description": "Average Profit Margin % across categories",
        "dax": "AVERAGEX(VALUES('Dim_Product'[Category]), [Profit Margin %])"
      },
      {
        "name": "Cumulative Net Revenue %",
        "home_table": "Fact_Sales",
        "format_string": "0.0%",
        "description": "Running cumulative share of Net Revenue by product rank (Pareto line)",
        "dax": "DIVIDE([Running Net Revenue], [Net Revenue (All Products)])"
      }
    ],
